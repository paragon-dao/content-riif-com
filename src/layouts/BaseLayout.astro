---
interface Props {
  title: string
  description?: string
  ogTitle?: string
  ogDescription?: string
  ogUrl?: string
  jsonLd?: object
}

const {
  title,
  description = 'Published research, technical documentation, and architecture papers from Paragon Biosignals.',
  ogTitle,
  ogDescription,
  ogUrl,
  jsonLd,
} = Astro.props

const canonicalUrl = ogUrl || Astro.url.href
const resolvedOgTitle = ogTitle || title
const resolvedOgDesc = ogDescription || description
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="RIIF Research" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDesc} />

    <meta name="theme-color" content="#0D9488" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f172a" media="(prefers-color-scheme: dark)" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Theme: apply before paint -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('content-theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Analytics -->
    <script defer src="https://mirrorai-api.amitacompany.workers.dev/t.js" data-site="sb_content_riif_01"></script>
  </head>
  <body class="bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-200 transition-colors">
    <slot />
  </body>
</html>

<style is:global>
  @import "tailwindcss";
  @custom-variant dark (&:where(.dark, .dark *));

  *, *::before, *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    -webkit-font-smoothing: antialiased;
  }
</style>
