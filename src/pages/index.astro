---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Paragon Biosignals',
  url: 'https://paragonbiosignals.com',
  description: 'AI fairness infrastructure for biosignal and genomic models. Published research on DCT-II encoding, bottleneck fairness, and cross-ancestry transfer.',
}
---

<BaseLayout
  title="RIIF Research — Biosignal AI, Genomic Fairness, Privacy"
  description="Published research from the RIIF ecosystem. Biosignal AI, genomic fairness, privacy-preserving encoding, and the General Learning Encoder. Built by Paragon Biosignals."
  jsonLd={jsonLd}
>
  <Nav />

  <main class="max-w-3xl mx-auto px-5 py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-bold text-slate-800 dark:text-slate-100 mb-3">RIIF Research</h1>
    <p class="text-lg text-slate-500 dark:text-slate-400 mb-5">Published research from the RIIF ecosystem. Built by Paragon Biosignals.</p>
    <div class="flex flex-wrap gap-2 mb-10 text-sm">
      <a href="https://paragonbiosignals.com" class="text-teal-600 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/30 px-3 py-1.5 rounded-full hover:bg-teal-100 dark:hover:bg-teal-900/50 transition-colors font-medium">Paragon Biosignals</a>
      <a href="https://haven.riif.com" class="text-teal-600 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/30 px-3 py-1.5 rounded-full hover:bg-teal-100 dark:hover:bg-teal-900/50 transition-colors font-medium">Haven Phone</a>
      <a href="https://paragondao.org" class="text-slate-600 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-3 py-1.5 rounded-full hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors font-medium">ParagonDAO</a>
    </div>

    <div class="space-y-5">
      {posts.map((post) => (
        <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="block group">
          <article class="border border-slate-200 dark:border-slate-700 rounded-2xl p-5 md:p-6 hover:border-teal-300 dark:hover:border-teal-600 hover:shadow-md transition-all bg-white dark:bg-slate-800/50">
            <div class="flex flex-wrap items-center gap-1.5 mb-2.5">
              {post.data.tags.map((tag) => (
                <span class="text-xs font-medium text-teal-700 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/30 px-2 py-0.5 rounded-full">{tag}</span>
              ))}
            </div>
            <h2 class="text-lg md:text-xl font-bold text-slate-800 dark:text-slate-100 group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors mb-2 leading-snug">{post.data.title}</h2>
            <p class="text-slate-500 dark:text-slate-400 text-sm mb-3 leading-relaxed line-clamp-2">{post.data.description}</p>
            <div class="flex flex-wrap items-center gap-2 text-xs text-slate-400 dark:text-slate-500">
              <span>{post.data.author}</span>
              <span>&middot;</span>
              <time datetime={post.data.date}>
                {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              {post.data.paper_url && (
                <>
                  <span>&middot;</span>
                  <span class="text-teal-600 dark:text-teal-400 font-medium">ResearchGate</span>
                </>
              )}
            </div>
          </article>
        </a>
      ))}
    </div>
  </main>

  <footer class="border-t border-slate-200 dark:border-slate-700 px-5 py-8">
    <div class="max-w-3xl mx-auto text-center">
      <div class="flex flex-wrap justify-center gap-4 text-xs text-slate-400 dark:text-slate-500 mb-3">
        <a href="https://paragonbiosignals.com" class="hover:text-slate-600 dark:hover:text-slate-300">Paragon Biosignals</a>
        <a href="https://haven.riif.com" class="hover:text-slate-600 dark:hover:text-slate-300">Haven Phone</a>
        <a href="https://paragondao.org" class="hover:text-slate-600 dark:hover:text-slate-300">ParagonDAO</a>
      </div>
      <p class="text-xs text-slate-400 dark:text-slate-500">RIIF Ecosystem &middot; Built by <a href="https://paragonbiosignals.com" class="hover:text-slate-600 dark:hover:text-slate-300">Paragon Biosignals</a></p>
    </div>
  </footer>
</BaseLayout>
