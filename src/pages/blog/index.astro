---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())

// Extract unique tags
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort()
---

<BaseLayout
  title="Research — Paragon Biosignals"
  description="Published research, technical documentation, and architecture papers from Paragon Biosignals. Covering biosignal AI, genomic fairness, privacy-preserving encoding, and atmospheric intelligence."
>
  <nav class="border-b border-slate-100 px-4 py-3 sticky top-0 z-40 bg-white/95 backdrop-blur-sm">
    <div class="max-w-3xl mx-auto flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/riif-logo.svg" alt="RIIF" class="h-7" />
        <span class="text-sm font-medium text-slate-400">Research</span>
      </a>
      <div class="flex items-center gap-5 text-sm">
        <a href="/blog" class="text-teal-600 font-medium">All Papers</a>
        <a href="https://paragonbiosignals.com" class="text-slate-500 hover:text-slate-800">Paragon Biosignals</a>
        <a href="https://haven.riif.com" class="text-slate-500 hover:text-slate-800">Haven Phone</a>
      </div>
    </div>
  </nav>

  <main class="max-w-3xl mx-auto px-5 py-12">
    <h1 class="text-3xl font-bold text-slate-800 mb-2">Research</h1>
    <p class="text-lg text-slate-500 mb-6">Published papers, technical documentation, and architecture analysis from Paragon Biosignals.</p>

    <!-- Tag filter -->
    <div class="flex flex-wrap gap-2 mb-10">
      <button class="tag-filter text-sm font-medium px-3 py-1.5 rounded-full border border-teal-200 bg-teal-50 text-teal-700" data-tag="all">All</button>
      {allTags.map((tag) => (
        <button class="tag-filter text-sm font-medium px-3 py-1.5 rounded-full border border-slate-200 text-slate-500 hover:border-teal-200 hover:text-teal-700 transition-colors" data-tag={tag}>{tag}</button>
      ))}
    </div>

    <div class="space-y-6" id="posts-list">
      {posts.map((post) => (
        <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="block group post-card" data-tags={post.data.tags.join(',')}>
          <article class="border border-slate-200 rounded-2xl p-6 hover:border-teal-200 hover:shadow-md transition-all">
            <div class="flex flex-wrap items-center gap-2 mb-3">
              {post.data.tags.map((tag) => (
                <span class="text-sm font-medium text-teal-700 bg-teal-50 px-2.5 py-1 rounded-full">{tag}</span>
              ))}
            </div>
            <h2 class="text-xl font-bold text-slate-800 group-hover:text-teal-600 transition-colors mb-2">{post.data.title}</h2>
            <p class="text-slate-500 text-sm mb-3 leading-relaxed">{post.data.description}</p>
            <div class="flex items-center gap-3 text-sm text-slate-400">
              <span>{post.data.author}</span>
              <span>&middot;</span>
              <time datetime={post.data.date}>
                {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
          </article>
        </a>
      ))}
    </div>
  </main>

  <footer class="border-t border-slate-100 px-5 py-10">
    <div class="max-w-3xl mx-auto text-center">
      <div class="flex justify-center gap-5 text-sm text-slate-400 mb-3">
        <a href="https://paragonbiosignals.com" class="hover:text-slate-600">Paragon Biosignals</a>
        <a href="https://haven.riif.com" class="hover:text-slate-600">Haven Phone</a>
        <a href="https://paragondao.org" class="hover:text-slate-600">ParagonDAO</a>
      </div>
      <p class="text-sm text-slate-400">Paragon Biosignals &middot; Salt Lake City, Utah</p>
    </div>
  </footer>
</BaseLayout>

<script>
  document.querySelectorAll('.tag-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag;
      // Update button styles
      document.querySelectorAll('.tag-filter').forEach(b => {
        b.classList.remove('bg-teal-50', 'text-teal-700', 'border-teal-200');
        b.classList.add('text-slate-500', 'border-slate-200');
      });
      btn.classList.remove('text-slate-500', 'border-slate-200');
      btn.classList.add('bg-teal-50', 'text-teal-700', 'border-teal-200');
      // Filter posts
      document.querySelectorAll('.post-card').forEach(card => {
        if (tag === 'all') {
          card.style.display = '';
        } else {
          const tags = card.dataset.tags.split(',');
          card.style.display = tags.includes(tag) ? '' : 'none';
        }
      });
    });
  });
</script>
