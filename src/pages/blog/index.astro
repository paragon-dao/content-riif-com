---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/Nav.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort()
---

<BaseLayout
  title="RIIF Research — All Papers"
  description="Published research from the RIIF ecosystem. Biosignal AI, genomic fairness, privacy-preserving encoding, and atmospheric intelligence. Built by Paragon Biosignals."
>
  <Nav />

  <main class="max-w-3xl mx-auto px-5 py-12">
    <h1 class="text-2xl md:text-3xl font-bold text-slate-800 dark:text-slate-100 mb-2">RIIF Research</h1>
    <p class="text-base text-slate-500 dark:text-slate-400 mb-6">Published papers and architecture analysis from the RIIF ecosystem.</p>

    <!-- Tag filter -->
    <div class="flex flex-wrap gap-1.5 mb-8">
      <button class="tag-filter text-xs font-medium px-2.5 py-1 rounded-full border border-teal-200 dark:border-teal-700 bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-400" data-tag="all">All</button>
      {allTags.map((tag) => (
        <button class="tag-filter text-xs font-medium px-2.5 py-1 rounded-full border border-slate-200 dark:border-slate-600 text-slate-500 dark:text-slate-400 hover:border-teal-200 dark:hover:border-teal-700 hover:text-teal-700 dark:hover:text-teal-400 transition-colors" data-tag={tag}>{tag}</button>
      ))}
    </div>

    <div class="space-y-5" id="posts-list">
      {posts.map((post) => (
        <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="block group post-card" data-tags={post.data.tags.join(',')}>
          <article class="border border-slate-200 dark:border-slate-700 rounded-2xl p-5 md:p-6 hover:border-teal-300 dark:hover:border-teal-600 hover:shadow-md transition-all bg-white dark:bg-slate-800/50">
            <div class="flex flex-wrap items-center gap-1.5 mb-2.5">
              {post.data.tags.map((tag) => (
                <span class="text-xs font-medium text-teal-700 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/30 px-2 py-0.5 rounded-full">{tag}</span>
              ))}
            </div>
            <h2 class="text-lg md:text-xl font-bold text-slate-800 dark:text-slate-100 group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors mb-2 leading-snug">{post.data.title}</h2>
            <p class="text-slate-500 dark:text-slate-400 text-sm mb-3 leading-relaxed line-clamp-2">{post.data.description}</p>
            <div class="flex flex-wrap items-center gap-2 text-xs text-slate-400 dark:text-slate-500">
              <span>{post.data.author}</span>
              <span>&middot;</span>
              <time datetime={post.data.date}>
                {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
          </article>
        </a>
      ))}
    </div>
  </main>

  <footer class="border-t border-slate-200 dark:border-slate-700 px-5 py-8">
    <div class="max-w-3xl mx-auto text-center">
      <div class="flex flex-wrap justify-center gap-4 text-xs text-slate-400 dark:text-slate-500 mb-3">
        <a href="https://paragonbiosignals.com" class="hover:text-slate-600 dark:hover:text-slate-300">Paragon Biosignals</a>
        <a href="https://haven.riif.com" class="hover:text-slate-600 dark:hover:text-slate-300">Haven Phone</a>
        <a href="https://paragondao.org" class="hover:text-slate-600 dark:hover:text-slate-300">ParagonDAO</a>
      </div>
      <p class="text-xs text-slate-400 dark:text-slate-500">RIIF Ecosystem &middot; Built by <a href="https://paragonbiosignals.com" class="hover:text-slate-600 dark:hover:text-slate-300">Paragon Biosignals</a></p>
    </div>
  </footer>
</BaseLayout>

<script>
  document.querySelectorAll('.tag-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag;
      document.querySelectorAll('.tag-filter').forEach(b => {
        b.classList.remove('bg-teal-50', 'dark:bg-teal-900/30', 'text-teal-700', 'dark:text-teal-400', 'border-teal-200', 'dark:border-teal-700');
        b.classList.add('text-slate-500', 'dark:text-slate-400', 'border-slate-200', 'dark:border-slate-600');
      });
      btn.classList.remove('text-slate-500', 'dark:text-slate-400', 'border-slate-200', 'dark:border-slate-600');
      btn.classList.add('bg-teal-50', 'dark:bg-teal-900/30', 'text-teal-700', 'dark:text-teal-400', 'border-teal-200', 'dark:border-teal-700');
      document.querySelectorAll('.post-card').forEach(card => {
        if (tag === 'all') { card.style.display = ''; }
        else { card.style.display = card.dataset.tags.split(',').includes(tag) ? '' : 'none'; }
      });
    });
  });
</script>
